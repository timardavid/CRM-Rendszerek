# Neon Postgres connection string (Vercel Marketplace vagy neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=verify-full"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 33"

# Cég neve — ez jelenik meg a CRM címeként regisztráció előtt is
NEXT_PUBLIC_DEFAULT_COMPANY_NAME="Autószerelő Kft."

# OAuth bejelentkezés (opcionális) — ha egy szolgáltatóhoz nincs kitöltve mindkét
# változó, a hozzá tartozó gomb egyszerűen nem jelenik meg a login/regisztráció oldalon.
# Bejelentkezés csak már létező (email alapján egyező) fiókkal lehetséges;
# kivétel az első, üres rendszerben történő admin-regisztráció.

# Google Cloud Console → APIs & Services → Credentials → Create OAuth client ID
# (Web application). Engedélyezett redirect URI: {origin}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# Authorization callback URL: {origin}/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
